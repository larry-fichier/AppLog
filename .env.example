# Configuration PostgreSQL (Recommandé)
# Remplacez les valeurs par vos vrais identifiants
DATABASE_URL=postgres://postgres:admin123@localhost:5432/helios_db

# Ou paramètres séparés
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=votre_mot_de_passe
# PGDATABASE=helios_db

# JWT Secret pour la sécurité des sessions
JWT_SECRET=super_secret_key_change_me
